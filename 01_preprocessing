parse_metadata_from_colnames <- function(seu, split_char = "_") {
  meta_split <- stringr::str_split(colnames(seu), pattern = split_char, simplify = TRUE)
  seu$group <- meta_split[, 1]
  if (ncol(meta_split) >= 2) seu$outcome <- meta_split[, 2]
  if (ncol(meta_split) >= 3) seu$number <- meta_split[, 3]
  if (ncol(meta_split) >= 4) seu$time <- meta_split[, 4]
  return(seu)
}

add_qc_metrics <- function(seu) {
  seu[["percent.mt"]] <- PercentageFeatureSet(seu, pattern = "^MT-")
  seu[["percent.hb"]] <- PercentageFeatureSet(seu, pattern = "^HB[^(P)]")
  seu[["percent.rb"]] <- PercentageFeatureSet(seu, pattern = "^RPS|RPL")
  return(seu)
}

filter_cells <- function(seu) {
  subset(
    seu,
    subset = nFeature_RNA > 200 &
      nFeature_RNA < 6000 &
      nCount_RNA < 30000 &
      percent.mt < 5
  )
}

read_create_seurat <- function(data_dir, project_name, min_cells = 3, min_features = 200) {
  x <- Read10X(data.dir = data_dir)
  CreateSeuratObject(
    counts = x,
    project = project_name,
    min.cells = min_cells,
    min.features = min_features
  )
}

