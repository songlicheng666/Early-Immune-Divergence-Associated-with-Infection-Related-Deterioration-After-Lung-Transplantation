seu_list <- lapply(names(sample_paths), function(nm) {
  message("Reading: ", nm)
  seu <- read_create_seurat(sample_paths[[nm]], nm)
  seu <- parse_metadata_from_colnames(seu)
  seu <- add_qc_metrics(seu)
  seu <- filter_cells(seu)
  return(seu)
})
names(seu_list) <- names(sample_paths)

pbmc_lt <- merge(
  x = seu_list[[1]],
  y = seu_list[-1],
  add.cell.ids = names(seu_list),
  project = "PBMC_LT"
)

pbmc_lt <- parse_metadata_from_colnames(pbmc_lt)
save(pbmc_lt, file = "PBMC_LT_raw_filtered.Rdata")

qc_plot <- VlnPlot(
  pbmc_lt,
  features = c("nFeature_RNA", "nCount_RNA", "percent.mt", "percent.hb", "percent.rb"),
  pt.size = 0.1,
  ncol = 5,
  assay = "RNA",
  layer = "counts"
)
ggsave("PBMC_LT_QC_violin.pdf", plot = qc_plot, width = 16, height = 5)

pbmc_lt <- NormalizeData(pbmc_lt)
pbmc_lt <- FindVariableFeatures(pbmc_lt)
pbmc_lt <- ScaleData(pbmc_lt, vars.to.regress = "percent.mt")
pbmc_lt <- RunPCA(pbmc_lt, verbose = FALSE)

pbmc_lt <- IntegrateLayers(
  object = pbmc_lt,
  method = HarmonyIntegration,
  orig.reduction = "pca",
  new.reduction = "integrated.harmony",
  verbose = FALSE
)

pbmc_lt <- FindNeighbors(pbmc_lt, reduction = "integrated.harmony", dims = 1:20)
pbmc_lt <- FindClusters(pbmc_lt, resolution = 0.8)
pbmc_lt <- RunUMAP(pbmc_lt, reduction = "integrated.harmony", dims = 1:20)

save(pbmc_lt, file = "PBMC_LT_integrated.Rdata")

avg_expr <- AverageExpression(pbmc_lt, group.by = "orig.ident", layer = "data")$RNA
expr_mat <- t(avg_expr)
expr_mat <- expr_mat[, apply(expr_mat, 2, sd) != 0]
pca_res <- prcomp(expr_mat, scale. = TRUE)

pca_df <- as.data.frame(pca_res$x)
pca_df$sample_id <- rownames(pca_df)

ggplot(pca_df, aes(PC1, PC2)) +
  geom_point(size = 3) +
  geom_text(aes(label = sample_id), size = 2.5, vjust = -1) +
  theme_minimal()

ggsave("sample_level_pca.pdf", width = 7, height = 6)
write.csv(pca_df, "sample_level_pca.csv", row.names = FALSE)
